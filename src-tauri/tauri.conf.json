{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Marker",
  "version": "1.4.1",
  "identifier": "com.marker.app",
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:6275",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**/*",
          "$APPDATA/**/*"
        ]
      },
      "capabilities": [
        {
          "identifier": "main",
          "description": "Main window access to filesystem, dialogs, shell, and store.",
          "windows": [
            "main"
          ],
          "permissions": [
            "core:default",
            "core:path:allow-join",
            "core:path:allow-resolve",
            "core:path:allow-resolve-directory",
            "core:menu:default",
            "core:event:default",
            "core:window:allow-create",
            "core:window:allow-maximize",
            "core:window:allow-unmaximize",
            "core:window:allow-start-dragging",
            "get-file-metadata",
            "scan-markdown-file-tree",
            "fs:read-all",
            "fs:write-all",
            {
              "identifier": "fs:scope",
              "allow": [
                "$HOME/**/*",
                "$APPDATA/**/*"
              ]
            },
            "dialog:default",
            "shell:allow-open",
            "shell:allow-execute",
            "store:default",
            "updater:default"
          ]
        }
      ]
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "center": true,
        "title": "Marker",
        "hiddenTitle": false,
        "titleBarStyle": "Transparent",
        "width": 800,
        "minWidth": 800,
        "minHeight": 400,
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "",
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": [
      "assets/"
    ],
    "shortDescription": "",
    "targets": "all",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "shell": {
      "open": "^(?:mailto:|https://|tel:).*\\?open=true$"
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/tk04/Marker/releases/download/master/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc3MTU3NzVGQ0U5NzQyMDEKUldRQlFwZk9YM2NWZHg1TUZLVlI1Z3VMOStTY1lSeENJb2R1cnpnQjgzZk5TS0c3SFFha2VPWVoK"
    }
  }
}
